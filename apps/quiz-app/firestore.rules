rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Allow any authenticated user with an @nu.ac.th email to read
      allow read: if request.auth != null && request.auth.token.email.matches(".*@nu\\.ac\\.th$");
      
      // Allow only the admin to write
      allow write: if request.auth != null && request.auth.token.email == "panupongs@nu.ac.th";
    }
  }
}
